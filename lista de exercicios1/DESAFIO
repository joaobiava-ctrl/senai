def executar_senha():
    senha_correta = "1234"
    limite_tentativas = 3
    
    print(" !!!SISTEMA DE SEGURANÇA!!! COFRE DIGITAL DO SENAI ")

    for tentativa_atual in range(1, limite_tentativas + 1):
        palpite = input(f"Digite a senha ({tentativa_atual}/{limite_tentativas}): ")

        if palpite == senha_correta:
            print("\n[SUCESSO] Acesso Permitido. Bem-vindo!")
            break 
        else:
            tentativas_restantes = limite_tentativas - tentativa_atual
            
            if tentativas_restantes > 0:
                print(f"Senha incorreta! Tentativas restantes: {tentativas_restantes}\n")
            else:
                print("\n[ALERTA] TENTATIVAS EXCEDIDAS!")
                print("!!! ALARME DISPARADO !!!")

if __name__ == "__main__":
    executar_senha()